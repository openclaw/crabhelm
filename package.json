{
  "name": "@openclaw/crabhelm",
  "version": "0.0.0",
  "private": true,
  "description": "Parent-core control plane for fleets of single-tenant OpenClaw child cores.",
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "build": "tsgo --noEmit && node --check web/app.js && esbuild index.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/index.js --external:openclaw/*",
    "check": "pnpm build && pnpm test",
    "dev": "tsx dev/server.ts",
    "prepack": "pnpm build",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.11"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260527.2",
    "esbuild": "0.28.1",
    "tsx": "4.22.3",
    "typebox": "1.1.39"
  },
  "files": [
    "dist",
    "web",
    "docs",
    "deploy",
    "README.md",
    "openclaw.plugin.json"
  ],
  "packageManager": "pnpm@11.2.2",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.6.11"
    }
  }
}
