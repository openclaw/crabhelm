{
  "schemaVersion": 1,
  "name": "fakeco",
  "repository": "openclaw/crabhelm",
  "partition": "aws",
  "stackName": "crabhelm-fakeco",
  "environments": {
    "deploy": "fakeco",
    "teardown": "fakeco-teardown",
    "imagePublish": "fakeco-image-publish"
  },
  "oidcSubjects": {
    "deploy": "repo:openclaw/crabhelm:environment:fakeco",
    "teardown": "repo:openclaw/crabhelm:environment:fakeco-teardown",
    "imagePublish": "repo:openclaw/crabhelm:environment:fakeco-image-publish"
  },
  "githubRolePaths": {
    "deploy": "openclaw/fakeco/github/crabhelm-deploy",
    "teardown": "openclaw/fakeco/github/crabhelm-teardown",
    "imagePublish": "openclaw/fakeco/github/crabhelm-image-publish"
  },
  "cloudFormationServiceRolePath": "openclaw/fakeco/cloudformation/crabhelm-service",
  "cloudFormationArtifactBucketPattern": "openclaw-fakeco-cfn-{accountId}-{region}",
  "workloadPermissionsBoundaryPath": "openclaw/fakeco/crabhelm-workload-boundary",
  "workloadRolePath": "/openclaw/fakeco/crabhelm/",
  "ecrRepositoryName": "openclaw/fakeco/crabhelm",
  "ecrRepositoryUriPattern": "{accountId}.dkr.ecr.{region}.amazonaws.com/openclaw/fakeco/crabhelm",
  "concurrencyGroup": "crabhelm-fakeco",
  "imagePublishConcurrencyGroup": "crabhelm-fakeco-image-publish",
  "imageScanPolicy": {
    "maximumCriticalFindings": 0
  },
  "tags": {
    "Environment": "fakeco",
    "ManagedBy": "github-actions",
    "Project": "crabhelm"
  },
  "lockedParameters": {
    "CreateEcrRepository": "false",
    "ProvisionService": "true",
    "WorkloadRolePath": "/openclaw/fakeco/crabhelm/",
    "IngressCidr": "0.0.0.0/0",
    "LoadBalancerDeletionProtection": "false",
    "OidcScopes": "openid email profile",
    "CrabboxProfile": "openclaw-core",
    "CrabboxTtlSeconds": "14400",
    "CrabboxIdleTimeoutSeconds": "14400",
    "AdminGroups": "",
    "ProbeEmail": "",
    "EgressLockdown": "required",
    "SlackMode": "off",
    "ClawRouterMode": "on",
    "ClawRouterTenantId": "fakeco",
    "ClawRouterAllowedProviders": "openai",
    "ClawRouterModelProviderMap": "clawrouter/openai/gpt-5.5=openai",
    "ClawRouterDefaultModel": "clawrouter/openai/gpt-5.5",
    "ClawRouterAccessServiceToken": "on",
    "DatabaseName": "crabhelm",
    "DatabaseInstanceClass": "db.t4g.micro",
    "DatabaseAllocatedStorage": "20",
    "DatabaseStorageAutoscaling": "false",
    "DatabaseMaxAllocatedStorage": "20",
    "DatabaseBackupRetentionDays": "1",
    "DatabaseLogExports": "off",
    "DatabaseMultiAz": "false",
    "DatabaseDeletionProtection": "false",
    "PostgresMajorVersion": "17",
    "LogRetentionDays": "7",
    "PrometheusMode": "on"
  },
  "foundationInputs": [
    { "env": "FAKECO_AWS_ACCOUNT_ID", "kind": "accountId" },
    { "env": "FAKECO_AWS_REGION", "kind": "region" },
    { "env": "FAKECO_GITHUB_ROLE_ARN", "kind": "githubRoleArn" },
    { "env": "FAKECO_CLOUDFORMATION_SERVICE_ROLE_ARN", "kind": "cloudFormationServiceRoleArn" },
    { "env": "FAKECO_CLOUDFORMATION_ARTIFACT_BUCKET", "kind": "cloudFormationArtifactBucket" },
    { "env": "FAKECO_ECR_REPOSITORY_ARN", "kind": "ecrRepositoryArn" }
  ],
  "imagePublicationInputs": [
    { "env": "FAKECO_AWS_ACCOUNT_ID", "kind": "accountId" },
    { "env": "FAKECO_AWS_REGION", "kind": "region" },
    { "env": "FAKECO_IMAGE_PUBLISH_ROLE_ARN", "kind": "imagePublishRoleArn" },
    { "env": "FAKECO_ECR_REPOSITORY_ARN", "kind": "ecrRepositoryArn" },
    { "env": "FAKECO_ECR_REPOSITORY_URI", "kind": "ecrRepositoryUri" }
  ],
  "parameterInputs": [
    { "env": "FAKECO_IMAGE_URI", "parameter": "ImageUri", "kind": "imageUri" },
    { "env": "FAKECO_ECR_REPOSITORY_ARN", "parameter": "ExistingEcrRepositoryArn", "kind": "ecrRepositoryArn" },
    { "env": "FAKECO_WORKLOAD_PERMISSIONS_BOUNDARY_ARN", "parameter": "WorkloadPermissionsBoundaryArn", "kind": "workloadPermissionsBoundaryArn" },
    { "env": "FAKECO_CERTIFICATE_ARN", "parameter": "CertificateArn", "kind": "certificateArn" },
    { "env": "FAKECO_CONSOLE_HOSTNAME", "parameter": "ConsoleHostname", "kind": "hostname" },
    { "env": "FAKECO_RUNTIME_HOSTNAME", "parameter": "RuntimeHostname", "kind": "hostname" },
    { "env": "FAKECO_OIDC_ISSUER", "parameter": "OidcIssuer", "kind": "httpsUrl" },
    { "env": "FAKECO_OIDC_AUTHORIZATION_ENDPOINT", "parameter": "OidcAuthorizationEndpoint", "kind": "httpsUrl" },
    { "env": "FAKECO_OIDC_TOKEN_ENDPOINT", "parameter": "OidcTokenEndpoint", "kind": "httpsUrl" },
    { "env": "FAKECO_OIDC_USERINFO_ENDPOINT", "parameter": "OidcUserInfoEndpoint", "kind": "httpsUrl" },
    { "env": "FAKECO_OIDC_CLIENT_ID", "parameter": "OidcClientId", "kind": "identifier" },
    { "env": "FAKECO_OIDC_CLIENT_SECRET_VERSION", "parameter": "OidcClientSecretVersion", "kind": "version" },
    { "env": "FAKECO_APPLICATION_SECRET_ARN", "parameter": "ApplicationSecretArn", "kind": "applicationSecretArn" },
    { "env": "FAKECO_APPLICATION_SECRET_KMS_KEY_ARN", "parameter": "ApplicationSecretKmsKeyArn", "kind": "kmsKeyArn" },
    { "env": "FAKECO_CRABBOX_URL", "parameter": "CrabboxUrl", "kind": "httpsUrl" },
    { "env": "FAKECO_CRABBOX_TARGET_ID", "parameter": "CrabboxTargetId", "kind": "dnsLabel" },
    { "env": "FAKECO_CRABBOX_TARGET_LABEL", "parameter": "CrabboxTargetLabel", "kind": "label" },
    { "env": "FAKECO_CRABBOX_TARGET_REGION", "parameter": "CrabboxTargetRegion", "kind": "identifier" },
    { "env": "FAKECO_ADMIN_EMAILS", "parameter": "AdminEmails", "kind": "emailList" },
    { "env": "FAKECO_GITHUB_OAUTH_CLIENT_ID", "parameter": "GitHubOauthClientId", "kind": "identifier" },
    { "env": "FAKECO_CLAWROUTER_BASE_URL", "parameter": "ClawRouterBaseUrl", "kind": "clawRouterUrl" },
    { "env": "FAKECO_NODE_RUNTIME_SHA256", "parameter": "NodeRuntimeSha256", "kind": "digest" },
    { "env": "FAKECO_APPLIANCE_ARCHIVE_SHA256", "parameter": "ApplianceArchiveSha256", "kind": "digest" },
    { "env": "FAKECO_APPLIANCE_MANIFEST_SHA256", "parameter": "ApplianceManifestSha256", "kind": "digest" },
    { "env": "FAKECO_OPERATOR_ALERT_TOPIC_NAME", "parameter": "OperatorAlertTopicName", "kind": "topicName" }
  ]
}
